# Environment variables for chapters-of-us
# Copy this file to .env.local and customize as needed.
# .env.local is gitignored and overrides other .env files.
# Restart the dev server after changes.

# Development server port (default: 3000)
PORT=3000

# Public base URL (used for absolute links and OpenGraph metadata)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional: override the anniversary date from config.json (YYYY-MM-DD)
# When set, this value is used for the "years" counter on the landing page.
NEXT_PUBLIC_ANNIVERSARY_DATE=2016-10-10
